{
  "name": "commitwright",
  "displayName": "CommitWright",
  "description": "Generate Git commit messages from your staged changes using your local Claude CLI.",
  "version": "0.0.1",
  "publisher": "mik8142",
  "author": {
    "name": "mik8142"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mik8142/CommitWright.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "commit message",
    "claude",
    "ai",
    "cli"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitwright.generate",
        "title": "Generate Commit Message",
        "category": "CommitWright",
        "icon": "$(chat-sparkle)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitwright.generate",
          "group": "navigation@-100",
          "when": "scmProvider == git && commitwright.pos.scmTitle == 'left'"
        },
        {
          "command": "commitwright.generate",
          "group": "navigation@100",
          "when": "scmProvider == git && commitwright.pos.scmTitle == 'right'"
        }
      ]
    },
    "configuration": {
      "title": "CommitWright",
      "properties": {
        "commitwright.cliPath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the CLI executable. Use an absolute path if it is not on PATH (common on Windows, e.g. C:\\\\Users\\\\you\\\\...\\\\claude.exe)."
        },
        "commitwright.model": {
          "type": "string",
          "default": "",
          "description": "Optional model override passed to the CLI. Leave empty to use the CLI default."
        },
        "commitwright.diffSource": {
          "type": "string",
          "enum": [
            "staged",
            "all"
          ],
          "default": "staged",
          "description": "Which changes to feed to the generator: only staged ('git diff --cached') or all tracked changes."
        },
        "commitwright.position.scmTitle": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "Pin the button to the left edge of the Source Control title actions.",
            "Pin the button to the right edge, just before the '...' overflow menu."
          ],
          "default": "right",
          "description": "Where to place the CommitWright button among the built-in Source Control title actions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "package": "npm run check-types && npm run lint && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "~1.90.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "npm-run-all2": "^9.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
