{
  "name": "commitwright",
  "displayName": "CommitWright",
  "description": "Generate Git commit messages from your staged changes using your local Claude CLI.",
  "version": "0.0.1",
  "publisher": "mik8142",
  "author": {
    "name": "mik8142"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mik8142/CommitWright.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#13314F",
    "theme": "dark"
  },
  "categories": [
    "SCM Providers",
    "AI",
    "Machine Learning"
  ],
  "keywords": [
    "git",
    "commit",
    "commit message",
    "claude",
    "ai",
    "cli"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "%cap.untrustedWorkspaces%"
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "%cap.virtualWorkspaces%"
    }
  },
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "commitwright.generate",
        "title": "%cmd.generate.title%",
        "category": "CommitWright",
        "icon": "$(chat-sparkle)"
      },
      {
        "command": "commitwright.selectLanguage",
        "title": "%cmd.selectLanguage.title%",
        "category": "CommitWright"
      },
      {
        "command": "commitwright.selectModel",
        "title": "%cmd.selectModel.title%",
        "category": "CommitWright"
      },
      {
        "command": "commitwright.configureEntrypoints",
        "title": "%cmd.configureEntrypoints.title%",
        "category": "CommitWright"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitwright.generate",
          "group": "navigation@-100",
          "when": "scmProvider == git && commitwright.show.scmTitle && commitwright.pos.scmTitle == 'left'"
        },
        {
          "command": "commitwright.generate",
          "group": "navigation@100",
          "when": "scmProvider == git && commitwright.show.scmTitle && commitwright.pos.scmTitle == 'right'"
        }
      ],
      "editor/title": [
        {
          "command": "commitwright.generate",
          "group": "navigation",
          "when": "resourceFilename == COMMIT_EDITMSG && commitwright.show.editorButton"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "commitwright.generate",
          "group": "inline",
          "when": "scmProvider == git && scmResourceGroup == index && commitwright.show.changesInline"
        },
        {
          "command": "commitwright.generate",
          "group": "inline",
          "when": "scmProvider == git && scmResourceGroup == workingTree && !commitwright.hasStaged && commitwright.show.changesInline"
        }
      ],
      "view/title": [
        {
          "command": "commitwright.generate",
          "group": "navigation",
          "when": "view == commitwright.panel"
        }
      ]
    },
    "keybindings": [
      {
        "command": "commitwright.generate",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "scmProvider == git || editorLangId == git-commit"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "commitwright.panel",
          "name": "CommitWright",
          "when": "scmProvider == git && commitwright.show.panel"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "commitwright.panel",
        "contents": "%view.welcome%"
      }
    ],
    "configuration": {
      "title": "CommitWright",
      "properties": {
        "commitwright.cliPath": {
          "type": "string",
          "default": "claude",
          "order": 12,
          "tags": [
            "usesOnlineServices"
          ],
          "description": "%cfg.cliPath.desc%"
        },
        "commitwright.model": {
          "type": "string",
          "default": "",
          "order": 10,
          "markdownDescription": "%cfg.model.desc%"
        },
        "commitwright.effort": {
          "type": "string",
          "enum": [
            "",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "enumItemLabels": [
            "%cfg.effort.label.default%",
            "%cfg.effort.label.low%",
            "%cfg.effort.label.medium%",
            "%cfg.effort.label.high%",
            "%cfg.effort.label.xhigh%",
            "%cfg.effort.label.max%"
          ],
          "enumDescriptions": [
            "%cfg.effort.enum.default%",
            "%cfg.effort.enum.low%",
            "%cfg.effort.enum.medium%",
            "%cfg.effort.enum.high%",
            "%cfg.effort.enum.xhigh%",
            "%cfg.effort.enum.max%"
          ],
          "default": "low",
          "order": 11,
          "markdownDescription": "%cfg.effort.desc%"
        },
        "commitwright.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "order": 13,
          "description": "%cfg.timeoutMs.desc%"
        },
        "commitwright.diffSource": {
          "type": "string",
          "enum": [
            "auto",
            "staged",
            "all"
          ],
          "enumDescriptions": [
            "%cfg.diffSource.enum.auto%",
            "%cfg.diffSource.enum.staged%",
            "%cfg.diffSource.enum.all%"
          ],
          "default": "auto",
          "order": 20,
          "description": "%cfg.diffSource.desc%"
        },
        "commitwright.includeChangedFiles": {
          "type": "boolean",
          "default": true,
          "order": 21,
          "description": "%cfg.includeChangedFiles.desc%"
        },
        "commitwright.style": {
          "type": "string",
          "enum": [
            "plain",
            "scoped",
            "conventional",
            "brackets"
          ],
          "enumItemLabels": [
            "%cfg.style.label.plain%",
            "%cfg.style.label.scoped%",
            "%cfg.style.label.conventional%",
            "%cfg.style.label.brackets%"
          ],
          "enumDescriptions": [
            "%cfg.style.enum.plain%",
            "%cfg.style.enum.scoped%",
            "%cfg.style.enum.conventional%",
            "%cfg.style.enum.brackets%"
          ],
          "default": "plain",
          "order": 30,
          "description": "%cfg.style.desc%"
        },
        "commitwright.messageMode": {
          "type": "string",
          "enum": [
            "subject",
            "subjectBody"
          ],
          "enumItemLabels": [
            "%cfg.messageMode.label.subject%",
            "%cfg.messageMode.label.subjectBody%"
          ],
          "enumDescriptions": [
            "%cfg.messageMode.enum.subject%",
            "%cfg.messageMode.enum.subjectBody%"
          ],
          "default": "subject",
          "order": 31,
          "description": "%cfg.messageMode.desc%"
        },
        "commitwright.commitLanguage": {
          "type": "string",
          "default": "auto",
          "order": 32,
          "markdownDescription": "%cfg.commitLanguage.desc%"
        },
        "commitwright.extraInstructions": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "order": 33,
          "description": "%cfg.extraInstructions.desc%"
        },
        "commitwright.promptTemplate": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "order": 34,
          "markdownDescription": "%cfg.promptTemplate.desc%"
        },
        "commitwright.position.scmTitle": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "%cfg.position.scmTitle.enum.left%",
            "%cfg.position.scmTitle.enum.right%"
          ],
          "default": "right",
          "order": 40,
          "description": "%cfg.position.scmTitle.desc%"
        },
        "commitwright.entrypoints": {
          "type": "object",
          "order": 41,
          "additionalProperties": false,
          "properties": {
            "scmTitle": { "type": "boolean", "description": "%cfg.entrypoints.scmTitle%" },
            "editorButton": { "type": "boolean", "description": "%cfg.entrypoints.editorButton%" },
            "changesInline": { "type": "boolean", "description": "%cfg.entrypoints.changesInline%" },
            "panel": { "type": "boolean", "description": "%cfg.entrypoints.panel%" },
            "slashTrigger": { "type": "boolean", "description": "%cfg.entrypoints.slashTrigger%" },
            "statusBar": { "type": "boolean", "description": "%cfg.entrypoints.statusBar%" }
          },
          "default": {
            "scmTitle": true,
            "editorButton": true,
            "changesInline": true,
            "panel": false,
            "slashTrigger": true,
            "statusBar": true
          },
          "description": "%cfg.entrypoints.desc%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "node esbuild.js --test",
    "test": "npm run check-types && npm run compile-tests && node --enable-source-maps --test \"out/test/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "~1.90.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "npm-run-all2": "^9.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
