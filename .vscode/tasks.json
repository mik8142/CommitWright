{
  "version": "2.0.0",
  "tasks": [
    {
      // Разовая сборка перед F5 (preLaunchTask). Задача завершается -> хост стартует.
      // Без фонового watch и без хрупких background-паттернов: F5 работает предсказуемо.
      // Для hot-reload во время разработки запускай в терминале: npm run watch
      "label": "build",
      "type": "shell",
      "command": "node esbuild.js",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          { "regexp": "^[✘▲] \\[([A-Z]+)\\] (.+)$", "severity": 1, "message": 2 },
          { "regexp": "^(?:\\t| {4})(?!\\s)([^:]+)(?::(\\d+))?(?::(\\d+))?:$", "file": 1, "line": 2, "column": 3 }
        ]
      }
    }
  ]
}
