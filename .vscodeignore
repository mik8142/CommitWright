# Что НЕ попадает в публикуемый .vsix. В пакет уходит только собранный dist/.

.vscode/**
.vscode-test/**
out/**
.git/**
.gitignore
.gitattributes

# Приватная обвязка — не в репозитории И не в пакете.
CLAUDE.md
.claude/**
contexts/**
**/*.local.json

# Исходники и конфиги сборки — в .vsix нужен только результат сборки (dist/).
src/**
esbuild.js
eslint.config.mjs
**/tsconfig.json
**/*.map

# node_modules не нужен: всё необходимое уже внутри dist/.
node_modules/**

# Графика README в пакете не нужна — Marketplace берёт её из GitHub (vsce переписывает
# относительные пути на raw.githubusercontent). В .vsix обязана попасть только иконка пакета.
media/**
!media/icon.png

# Русский перевод README: витрина Marketplace рендерит только README.md, перевод читают на GitHub.
README.ru.md
